{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://alicebot.local/schemas/memory.schema.json",
  "title": "Alice vNext Memory",
  "type": "object",
  "required": [
    "id",
    "memory_type",
    "canonical_text",
    "status",
    "confidence",
    "domain",
    "sensitivity",
    "first_seen_at",
    "last_seen_at"
  ],
  "properties": {
    "id": { "type": "string" },
    "memory_type": {
      "enum": [
        "episode",
        "semantic",
        "project_state",
        "decision",
        "belief",
        "thesis",
        "person",
        "relationship",
        "open_loop",
        "preference",
        "value",
        "pattern",
        "contradiction",
        "question",
        "answer",
        "artifact_summary",
        "agent_run",
        "system"
      ]
    },
    "title": { "type": ["string", "null"] },
    "canonical_text": { "type": "string" },
    "summary": { "type": ["string", "null"] },
    "status": {
      "enum": [
        "candidate",
        "active",
        "accepted",
        "rejected",
        "superseded",
        "archived",
        "needs_review",
        "private_only"
      ]
    },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "domain": { "$ref": "source.schema.json#/properties/domain" },
    "sensitivity": { "$ref": "source.schema.json#/properties/sensitivity" },
    "valid_from": { "type": ["string", "null"], "format": "date-time" },
    "valid_to": { "type": ["string", "null"], "format": "date-time" },
    "first_seen_at": { "type": "string", "format": "date-time" },
    "last_seen_at": { "type": "string", "format": "date-time" },
    "last_reviewed_at": { "type": ["string", "null"], "format": "date-time" },
    "metadata_json": { "type": "object" }
  },
  "additionalProperties": true
}
